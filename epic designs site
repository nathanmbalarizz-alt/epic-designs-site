<!DOCTYPE html>
<html>
<head>
<title>Epic Designs</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
body{margin:0;font-family:sans-serif;background:#0b1220;color:white}
.sidebar{width:230px;height:100vh;position:fixed;background:#020617;padding:20px}
.sidebar h2{color:#60a5fa}
.sidebar button{display:block;width:100%;margin:10px 0;padding:12px;background:#111827;border:none;border-radius:10px;color:white}
.main{margin-left:250px;padding:25px}
.card{background:#111827;padding:20px;border-radius:15px;margin-bottom:20px;box-shadow:0 0 15px rgba(0,0,0,0.4)}
input{padding:10px;border-radius:8px;border:none;margin:5px}
</style>
</head>
<body>

<div class="sidebar">
<h2>Epic Designs</h2>
<button onclick="show('dashboard')">Dashboard</button>
<button onclick="show('files')">Files</button>
<button onclick="show('admin')">Admin</button>
<button onclick="login()">Login</button>
</div>

<div class="main">

<div id="dashboard" class="card">
<h2>Analytics</h2>
<canvas id="chart"></canvas>
</div>

<div id="files" class="card" style="display:none">
<h2>Your Files</h2>
<div id="fileList"></div>
</div>

<div id="admin" class="card" style="display:none">
<h2>Admin Panel</h2>

<h3>Upload File</h3>
<form id="uploadForm">
<input type="text" id="userId" placeholder="User ID" required>
<input type="file" id="file" required>
<button type="submit">Upload</button>
</form>

</div>

</div>

<script>
function show(id){
 ['dashboard','files','admin'].forEach(x=>document.getElementById(x).style.display='none');
 document.getElementById(id).style.display='block';
}

function login(){ window.location.href='/auth/discord'; }

// Load files
fetch('/files').then(r=>r.json()).then(data=>{
 let html='';
 data.forEach(f=> html+=`<p><a href="${f.url}" target="_blank">Download</a></p>`);
 document.getElementById('fileList').innerHTML=html;
});

// Upload
const form = document.getElementById('uploadForm');
form?.addEventListener('submit', async e=>{
 e.preventDefault();
 const formData = new FormData();
 formData.append('userId', document.getElementById('userId').value);
 formData.append('file', document.getElementById('file').files[0]);

 await fetch('/admin/upload',{method:'POST',body:formData});
 alert('Uploaded');
});

// Analytics graph
fetch('/admin/analytics').then(r=>r.json()).then(data=>{
 new Chart(document.getElementById('chart'),{
  type:'bar',
  data:{
   labels:['Users','Orders','Revenue'],
   datasets:[{data:[data.users,data.orders,data.revenue]}]
  }
 });
});
</script>

</body>
</html>


// ================= BACKEND =================

const express = require('express');
const mongoose = require('mongoose');
const multer = require('multer');
const session = require('express-session');

const app = express();

// ================= CONFIG =================
const ADMIN_IDS = ['YOUR_DISCORD_ID'];

// ================= DB =================
mongoose.connect(process.env.MONGO_URI);

const File = mongoose.model('File',{userId:String,url:String});
const Order = mongoose.model('Order',{userId:String,item:String,price:Number});
const User = mongoose.model('User',{discordId:String});

// ================= AUTH CHECK =================
function isAdmin(req,res,next){
 if(!req.user || !ADMIN_IDS.includes(req.user.discordId)) return res.sendStatus(403);
 next();
}

// ================= FILE UPLOAD =================
const storage = multer.diskStorage({
 destination:'uploads/',
 filename:(req,file,cb)=> cb(null,Date.now()+file.originalname)
});
const upload = multer({storage});

app.use('/uploads', express.static('uploads'));

app.post('/admin/upload', isAdmin, upload.single('file'), async (req,res)=>{
 const fileUrl = `/uploads/${req.file.filename}`;
 await File.create({userId:req.body.userId,url:fileUrl});
 res.send('Uploaded');
});

// ================= FILE FETCH =================
app.get('/files', async (req,res)=>{
 if(!req.user) return res.json([]);
 const files = await File.find({userId:req.user.discordId});
 res.json(files);
});

// ================= AUTO DELIVERY =================
app.post('/verify', async (req,res)=>{
 if(!req.user) return res.json({verified:false});

 const owns = true; // replace with real check

 if(owns){
  await Order.create({userId:req.user.discordId,item:'Design',price:10});
  await File.create({userId:req.user.discordId,url:'/uploads/sample.png'});
  return res.json({verified:true});
 }

 res.json({verified:false});
});

// ================= ANALYTICS =================
app.get('/admin/analytics', async (req,res)=>{
 const users = await User.countDocuments();
 const orders = await Order.countDocuments();
 const revenueData = await Order.find();

 let revenue = 0;
 revenueData.forEach(o=> revenue += o.price || 0);

 res.json({users,orders,revenue});
});

app.listen(3000,()=>console.log('Enterprise v3 running'));


